@model ModernArtPrints.Models.Product

@{
    ViewData["Title"] = Model.Name;

    var approvedReviews = Model.ProductReviews != null
        ? Model.ProductReviews.Where(r => r.IsApproved).ToList()
        : new List<ProductReview>();

    var avgRating = approvedReviews.Any()
        ? approvedReviews.Average(r => r.Rating)
        : 0;

    var reviewCount = approvedReviews.Count;

    var mainImage = string.IsNullOrEmpty(Model.MainImageUrl)
        ? "/uploads/general/placeholder.jpg"
        : Model.MainImageUrl;
}

<!-- Top Bar -->
<div class="shop-filter-bar">
    <div class="container d-flex justify-content-between align-items-center">

        <a asp-area="" asp-controller="Product" asp-action="Shop"
           class="shop-category-pill">
            <i class="anm anm-angle-left-l"></i>
            Back to Shop
        </a>

        <a asp-area="" asp-controller="Cart" asp-action="Index"
           class="shop-icon-link">
            <i class="anm anm-cart-l" style="font-size: 1.35rem;"></i>
            <span id="cart-count" class="shop-cart-count">
                @ViewBag.CartCount
            </span>
        </a>

    </div>
</div>

<!-- Product Detail -->
<section class="product-detail-page art-page-bg">
    <div class="container">

        <div class="product-detail-card">
            <div class="row g-0 align-items-stretch">

                <!-- LEFT: Images -->
                <div class="col-12 col-lg-6 p-4 p-lg-5">

                    <div class="product-detail-image-box">
                        <img id="mainImage"
                             src="@mainImage"
                             alt="@Model.Name"
                             class="product-detail-main-img" />

                        @if (Model.StockQuantity > 0)
                        {
                            <span class="product-detail-badge">Available</span>
                        }
                        else
                        {
                            <span class="product-detail-badge" style="background:#dc3545;">Out of Stock</span>
                        }
                    </div>

                    @if (Model.ProductImages != null && Model.ProductImages.Any())
                    {
                        <div class="product-gallery-row">

                            <img src="@mainImage"
                                 alt="Main Image"
                                 class="product-gallery-thumb"
                                 onclick="document.getElementById('mainImage').src = this.src" />

                            @foreach (var image in Model.ProductImages)
                            {
                                <img src="@image.ImageUrl"
                                     alt="@Model.Name"
                                     class="product-gallery-thumb"
                                     onclick="document.getElementById('mainImage').src = this.src" />
                            }

                        </div>
                    }

                </div>
                <!-- END LEFT -->
                <!-- RIGHT: Details -->
                <div class="col-12 col-lg-6">

                    <div class="product-detail-content">

                        <span class="product-detail-category">
                            @(Model.Category?.Name ?? "Art Print")
                        </span>

                        <h1 class="product-detail-title">
                            @Model.Name
                        </h1>

                        <div class="product-detail-rating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= Math.Round(avgRating))
                                {
                                    <span class="star">★</span>
                                }
                                else
                                {
                                    <span class="star" style="color:#d8cfc7;">★</span>
                                }
                            }

                            <span class="review-count">
                                @avgRating.ToString("0.0") / 5
                                (@reviewCount review@(reviewCount != 1 ? "s" : ""))
                            </span>
                        </div>

                        <div class="product-detail-price">
                            $@Model.Price.ToString("0.00")
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <p class="product-detail-description">
                                @Model.Description
                            </p>
                        }
                        else
                        {
                            <p class="product-detail-description">
                                A curated modern art print designed to add warmth, personality,
                                and style to your space.
                            </p>
                        }

                        @if (Model.StockQuantity > 0)
                        {
                            <div class="product-detail-stock in-stock">
                                In Stock (@Model.StockQuantity available)
                            </div>
                        }
                        else
                        {
                            <div class="product-detail-stock out-stock">
                                Out of Stock
                            </div>
                        }

                        <div class="product-detail-actions">

                            <form method="post"
                                  action="/Cart/Add"
                                  class="detail-add-to-cart-form"
                                  style="margin:0;">

                                @Html.AntiForgeryToken()

                                <input type="hidden" name="productId" value="@Model.Id" />

                                <input type="number"
                                       name="quantity"
                                       value="1"
                                       min="1"
                                       max="@Model.StockQuantity"
                                       class="form-control product-detail-qty"
                                @(Model.StockQuantity == 0 ? "disabled" : "") />

                                <button type="submit"
                                        class="product-detail-add-btn detail-add-cart-btn"
                                @(Model.StockQuantity == 0 ? "disabled" : "")>
                                    @(Model.StockQuantity == 0 ? "Out of Stock" : "Add to Cart")
                                </button>

                            </form>

                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <form method="post" action="/Wishlist/Add" style="margin:0;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@Model.Id" />

                                    <button type="submit" class="product-detail-wishlist-btn">
                                        <i class="anm anm-heart-l"></i>
                                        Wishlist
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a asp-area="Identity"
                                   asp-page="/Account/Login"
                                   class="product-detail-wishlist-btn">
                                    <i class="anm anm-heart-l"></i>
                                    Wishlist
                                </a>
                            }

                        </div>

                        <div class="mt-4 pt-4" style="border-top:1px solid rgba(138,90,68,0.14);">
                            <p class="mb-2" style="color:var(--art-muted);">
                                <strong style="color:var(--art-dark);">Category:</strong>
                                @(Model.Category?.Name ?? "Not specified")
                            </p>

                            <p class="mb-0" style="color:var(--art-muted);">
                                <strong style="color:var(--art-dark);">Product ID:</strong>
                                #@Model.Id
                            </p>
                        </div>

                    </div>

                </div>
                <!-- END RIGHT -->

            </div>
        </div>

    </div>
</section>
<!-- End Product Detail -->
<!-- Gallery Section -->
@if (Model.ProductImages != null && Model.ProductImages.Any())
{
    <section class="product-reviews-section art-page-bg">
        <div class="container">
            <div class="product-reviews-card">
                <div class="section-title text-center mb-4">
                    <span class="section-label">Gallery</span>
                    <h2>More Product Views</h2>
                    <p>Explore additional images of this art print.</p>
                </div>

                <div class="row g-4">
                    @foreach (var image in Model.ProductImages)
                    {
                        <div class="col-6 col-md-4 col-lg-3">
                            <div class="product-detail-image-box"
                                 style="cursor:pointer;"
                                 onclick="document.getElementById('mainImage').src = '@image.ImageUrl'; window.scrollTo({ top: 0, behavior: 'smooth' });">
                                <img src="@image.ImageUrl"
                                     alt="@Model.Name"
                                     class="product-premium-image"
                                     style="height:220px;" />
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
}

<!-- Reviews Section -->
<section class="product-reviews-section art-page-bg">
    <div class="container">

        <div class="product-reviews-card">

            <div class="section-title text-center mb-5">
                <span class="section-label">Customer Reviews</span>
                <h2>What Customers Say</h2>
                <p>
                    Real feedback from customers who purchased this product.
                </p>
            </div>

            @if (reviewCount == 0)
            {
                <div class="no-reviews-box">
                    <i class="anm anm-star-o"></i>
                    <h4>No approved reviews yet</h4>
                    <p class="mb-0">Reviews will appear here after admin approval.</p>
                </div>
            }
            else
            {
                @foreach (var review in approvedReviews.OrderByDescending(r => r.CreatedAt))
                {
                    var userImage = string.IsNullOrEmpty(review.User?.ProfileImageUrl)
                    ? "/uploads/users/AdminPic.jpeg"
                    : review.User.ProfileImageUrl;

                    <div class="review-display-card">

                        <div class="d-flex align-items-center gap-3 mb-3">

                            <img src="@userImage"
                                 alt="@(review.User?.FullName ?? "Customer")"
                                 style="width:52px; height:52px; border-radius:50%; object-fit:cover; border:2px solid #f1e9e2;" />

                            <div>
                                <div class="review-display-user" style="color:var(--art-dark); font-weight:800;">
                                    @(review.User?.FullName ?? "Anonymous Customer")
                                </div>

                                <div style="font-size:0.78rem; color:var(--art-muted);">
                                    @review.CreatedAt.ToString("MMM dd, yyyy")
                                </div>
                            </div>

                            <div class="ms-auto review-display-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= review.Rating)
                                    {
                                        <span>★</span>
                                    }
                                    else
                                    {
                                        <span style="color:#d8cfc7;">★</span>
                                    }
                                }
                            </div>

                        </div>

                        <p class="review-display-text mb-0">
                            @review.CommentText
                        </p>

                    </div>
                }
            }

        </div>

    </div>
</section>

<!-- Detail Page Toast -->
<div id="detailCartToast" class="shop-cart-toast">
    <div class="shop-cart-toast-icon">✓</div>

    <div>
        <strong id="detailCartToastTitle">Added to Cart</strong>
        <p id="detailCartToastMessage">Item has been added to your cart.</p>
    </div>
</div>

<script>
    function showDetailCartToast(message, isSuccess = true) {
        const toast = document.getElementById("detailCartToast");
        const title = document.getElementById("detailCartToastTitle");
        const messageBox = document.getElementById("detailCartToastMessage");

        if (!toast || !title || !messageBox) {
            return;
        }

        title.textContent = isSuccess ? "Added to Cart" : "Cart Error";
        messageBox.textContent = message;

        toast.classList.remove("show", "error");

        if (!isSuccess) {
            toast.classList.add("error");
        }

        void toast.offsetWidth;

        toast.classList.add("show");

        setTimeout(function () {
            toast.classList.remove("show");
        }, 3500);
    }

    const detailCartForm = document.querySelector(".detail-add-to-cart-form");

    if (detailCartForm) {
        detailCartForm.addEventListener("submit", async function (e) {
            e.preventDefault();

            const formData = new FormData(detailCartForm);

            try {
                const response = await fetch("/Cart/Add", {
                    method: "POST",
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    const cartCount = document.getElementById("cart-count");

                    if (cartCount && data.cartCount !== undefined) {
                        cartCount.textContent = data.cartCount;
                    }

                    const button = detailCartForm.querySelector(".detail-add-cart-btn");
                    const originalText = button.innerHTML;

                    button.innerHTML = "Added ✓";
                    button.style.background = "#2ecc71";
                    button.disabled = true;

                    setTimeout(() => {
                        button.innerHTML = originalText;
                        button.style.background = "";
                        button.disabled = false;
                    }, 1200);

                    showDetailCartToast(data.message || "Item has been added to your cart.", true);
                } else {
                    showDetailCartToast(data.message || "Could not add item to cart.", false);
                }
            } catch (error) {
                showDetailCartToast("Something went wrong. Please try again.", false);
            }
        });
    }
</script>