<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Modern Art Prints</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ModernArtPrints.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />


    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta name="description" content="description">

    <!-- Favicon -->
    <link rel="shortcut icon" href="~/template/assets/images/favicon.png" />
    <!-- Plugins CSS -->
    <link rel="stylesheet" href="~/template/assets/css/plugins.css">
    <!-- Main Style CSS -->
    <link rel="stylesheet" href="~/template/assets/css/style.css">
    <link rel="stylesheet" href="~/template/assets/css/responsive.css">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

</head>


<body>


    <!-- Header Partial Layout-->
    @if (ViewData["HeaderType"]?.ToString() == "includeNavbar")
    {
        @await Html.PartialAsync("_Header")
        @await Html.PartialAsync("_HeaderNavBar")
    }
    else
    {
        @await Html.PartialAsync("_Header")
    }


    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <!-- Footer Partial Layout-->
    @await Html.PartialAsync("_Footer")


    

    @await RenderSectionAsync("Scripts", required: false)


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Including Jquery -->
    <script src="~/template/assets/js/vendor/jquery-min.js"></script>
    <script src="~/template/assets/js/vendor/js.cookie.js"></script>
    <!-- Including Javascript -->
    <script src="~/template/assets/js/plugins.js"></script>
    <script src="~/template/assets/js/main.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Swiper JS -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
</body>

</html>
