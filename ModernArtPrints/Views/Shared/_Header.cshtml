@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;

    var profileImage = string.IsNullOrEmpty(currentUser?.ProfileImageUrl)
        ? "/uploads/users/AdminPic.jpeg"
        : currentUser.ProfileImageUrl;

    var fullName = currentUser?.FullName ?? currentUser?.Email ?? "User";

    var isAdmin = currentUser != null && await UserManager.IsInRoleAsync(currentUser, "Admin");
}

<header class="header animated header-10">
    <div class="d-flex align-items-center">
        <div class="container">
            <div class="row align-items-center py-2">

                <!--Mobile Layout-->
                <div class="d-flex d-lg-none align-items-center justify-content-between w-100 px-2">

                    <!-- Hamburger on the LEFT -->
                    <button type="button" class="btn--link site-header__menu"
                            data-bs-toggle="offcanvas"
                            data-bs-target="#mobileMenu"
                            style="background:none; border:none; padding:0;">
                        <i class="anm anm-bars-r" style="font-size: 1.4rem;"></i>
                    </button>

                    <!-- Logo + Title in the CENTER -->
                    <a asp-area="" asp-controller="User" asp-action="Index" class="d-flex align-items-center text-decoration-none" style="gap: 6px;">
                        <img src="~/uploads/general/logo.png"
                             alt="Website Logo"
                             style="width: 35px; height: 35px; object-fit: contain; border-radius: 6px;">
                        <span style="font-size: 1rem; font-weight: bold; color: #333;">
                            @* Modern Art *@
                            Havenly
                        </span>
                    </a>

                    <!-- Auth buttons on the RIGHT (Mobile) -->
                    <div class="d-flex align-items-center" style="gap: 5px;">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <a asp-controller="Profile" asp-action="Index"
                                   class="d-flex align-items-center text-decoration-none" style="gap: 6px;">
                                <img src="@profileImage"
                                     alt="Profile"
                                     style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover; border: 2px solid #222;">
                                <span style="font-size: 0.78rem; font-weight: 600; color: #222;">
                                    @fullName
                                </span>
                            </a>
                            @if (isAdmin)
                            {
                                <a asp-area="Admin" asp-controller="Home" asp-action="Index"
                                   class="btn btn-dark btn-sm"
                                   style="border-radius: 20px; padding: 4px 10px; font-size: 0.75rem; font-weight: 600;">
                                    Dashboard
                                </a>
                            }
                            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" style="margin:0;">
                                <button type="submit" class="btn btn-outline-dark btn-sm"
                                        style="border-radius: 20px; padding: 4px 10px; font-size: 0.75rem; font-weight: 600;">
                                    Logout
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login"
                                   class="btn btn-outline-dark btn-sm"
                                   style="border-radius: 20px; padding: 4px 10px; font-size: 0.75rem; font-weight: 600;">
                                Login
                            </a>
                            <a asp-area="Identity" asp-page="/Account/Register"
                                   class="btn btn-dark btn-sm"
                                   style="border-radius: 20px; padding: 4px 10px; font-size: 0.75rem; font-weight: 600;">
                                Sign Up
                            </a>
                        }
                    </div>

                </div>
                <!--End Mobile Layout-->
                <!--Desktop Layout-->
                <!-- Logo and Website Title -->
                <div class="d-none d-lg-flex col-lg-5 align-self-center">
                    <a asp-area="" asp-controller="User" asp-action="Index" class="d-flex align-items-center text-decoration-none" style="gap: 10px;">
                        <img src="~/uploads/general/logo.png"
                             alt="Website Logo"
                             style="width: 55px; height: 55px; object-fit: contain; border-radius: 8px;">
                        <span style="font-size: 1.3rem; font-weight: bold; color: #333;">
                            @* Modern Art *@
                            Havenly
                        </span>
                    </a>
                </div>

                <!-- Spacer -->
                <div class="d-none d-lg-block col-lg-2"></div>

                <!-- Auth buttons desktop -->
                <div class="d-none d-lg-flex col-lg-5 align-self-center icons-col justify-content-end">
                    <div class="d-inline-flex align-items-center" style="gap: 8px;">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <a asp-controller="Profile" asp-action="Index"
                                   class="d-flex align-items-center text-decoration-none" style="gap: 8px;">
                                <img src="@profileImage"
                                     alt="Profile"
                                     style="width: 38px; height: 38px; border-radius: 50%; object-fit: cover; border: 2px solid #222;">
                                <span style="font-size: 0.85rem; font-weight: 700; color: #222; text-transform: uppercase; letter-spacing: 1px;">
                                    @fullName
                                </span>
                            </a>
                            @if (isAdmin)
                            {
                                <a asp-area="Admin" asp-controller="Home" asp-action="Index"
                                   style="display:inline-block; border-radius: 4px; border: 2px solid #8a5a44; color: #fff; background: #8a5a44; padding: 6px 16px; font-weight: 700; font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; text-decoration: none;">
                                    Dashboard
                                </a>
                            }
                            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" style="margin:0;">
                                <button type="submit"
                                        style="display:inline-block; border-radius: 4px; border: 2px solid #222; color: #fff; background: #222; padding: 6px 16px; font-weight: 700; font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; cursor: pointer;">
                                    Logout
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login"
                                   style="display:inline-block; border-radius: 4px; border: 2px solid #222; color: #222; background: transparent; padding: 6px 16px; font-weight: 700; font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; text-decoration: none;">
                                Login
                            </a>
                            <a asp-area="Identity" asp-page="/Account/Register"
                                   style="display:inline-block; border-radius: 4px; border: 2px solid #222; color: #fff; background: #222; padding: 6px 16px; font-weight: 700; font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; text-decoration: none;">
                                Sign Up
                            </a>
                        }
                    </div>
                </div>
                <!--End Desktop Layout-->

            </div>
        </div>
    </div>
</header>


<!-- Bootstrap Offcanvas Mobile Menu -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="mobileMenu">

    <div class="offcanvas-header">
        <div class="d-flex align-items-center" style="gap: 10px;">
            <img src="~/uploads/general/logo.png"
                 alt="Logo"
                 style="width: 40px; height: 40px; object-fit: contain; border-radius: 8px;">
            <h5 class="offcanvas-title mb-0">Havenly</h5>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>

    <div class="offcanvas-body">
        <ul class="list-unstyled">
            <li class="border-bottom py-3">
                <a href="/User/Index#home" class="text-decoration-none text-dark fw-bold" data-bs-dismiss="offcanvas">Home</a>
            </li>
            <li class="border-bottom py-3">
                <a href="/User/Index#about" class="text-decoration-none text-dark fw-bold" data-bs-dismiss="offcanvas">ABOUT</a>
            </li>
            <li class="border-bottom py-3">
                <a href="/User/Index#categories" class="text-decoration-none text-dark fw-bold" data-bs-dismiss="offcanvas">CATEGORIES</a>
            </li>
            <li class="border-bottom py-3">
                <a href="/User/Index#sale" class="text-decoration-none text-dark fw-bold" data-bs-dismiss="offcanvas">SALE</a>
            </li>
            <li class="border-bottom py-3">
                <a href="/User/Index#testimonials" class="text-decoration-none text-dark fw-bold" data-bs-dismiss="offcanvas">TESTIMONIALS</a>
            </li>
            <li class="border-bottom py-3">
                <a href="/User/Index#contact" class="text-decoration-none text-dark fw-bold" data-bs-dismiss="offcanvas">CONTACT US</a>
            </li>
        </ul>

        <div class="d-flex flex-column mt-3" style="gap: 10px;">
            @if (SignInManager.IsSignedIn(User))
            {
                <a asp-controller="Profile" asp-action="Index"
                       class="d-flex align-items-center text-decoration-none" style="gap: 10px;">
                    <img src="@profileImage"
                         alt="Profile"
                         style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid #222;">
                    <span style="font-weight: 700; font-size: 0.9rem; color: #222;">
                        @fullName
                    </span>
                </a>
                @if (isAdmin)
                {
                    <a asp-area="Admin" asp-controller="Home" asp-action="Index"
                       style="display:inline-block; width:100%; text-align:center; border-radius: 4px; border: 2px solid #8a5a44; color: #fff; background: #8a5a44; padding: 6px 16px; font-weight: 700; font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; text-decoration: none;">
                        Dashboard
                    </a>
                }
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" style="margin:0;">
                    <button type="submit"
                            style="width:100%; border-radius: 4px; border: 2px solid #222; color: #fff; background: #222; padding: 6px 16px; font-weight: 700; font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; cursor: pointer;">
                        Logout
                    </button>
                </form>
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Login"
                       style="display:inline-block; border-radius: 4px; border: 2px solid #222; color: #222; background: transparent; padding: 6px 16px; font-weight: 700; font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; text-decoration: none;">
                    Login
                </a>
                <a asp-area="Identity" asp-page="/Account/Register"
                       style="display:inline-block; border-radius: 4px; border: 2px solid #222; color: #fff; background: #222; padding: 6px 16px; font-weight: 700; font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; text-decoration: none;">
                    Sign Up
                </a>
            }
        </div>
    </div>
</div>