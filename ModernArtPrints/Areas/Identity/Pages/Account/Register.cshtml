@page
@model RegisterModel

@{
    ViewData["Title"] = "Register";
}

<section class="auth-premium-page art-page-bg">
    <div class="container">

        <div class="auth-premium-wrapper">

            <div class="auth-premium-side">
                <span>Join Havenly</span>
                <h1>Create your art account</h1>
                <p>
                    Sign up to explore curated modern art prints, save your wishlist,
                    manage your cart, track orders, and share your experience.
                </p>
            </div>

            <div class="auth-premium-form">
                <h2>Create Account</h2>
                <p class="auth-subtitle">
                    Fill in your details and start discovering art prints made for your space.
                </p>

                <form id="registerForm"
                      asp-route-returnUrl="@Model.ReturnUrl"
                      method="post"
                      enctype="multipart/form-data">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="form-floating">
                        <input asp-for="Input.FullName"
                               class="form-control"
                               placeholder="Full Name" />
                        <label asp-for="Input.FullName">Full Name</label>
                        <span asp-validation-for="Input.FullName" class="text-danger"></span>
                    </div>

                    <div class="form-floating">
                        <input asp-for="Input.Email"
                               class="form-control"
                               autocomplete="username"
                               placeholder="name@example.com" />
                        <label asp-for="Input.Email">Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating">
                        <input asp-for="Input.Password"
                               class="form-control"
                               autocomplete="new-password"
                               placeholder="Password" />
                        <label asp-for="Input.Password">Password</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-floating">
                        <input asp-for="Input.ConfirmPassword"
                               class="form-control"
                               autocomplete="new-password"
                               placeholder="Confirm Password" />
                        <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="form-floating">
                        <input asp-for="Input.Address"
                               class="form-control"
                               placeholder="Address" />
                        <label asp-for="Input.Address">Address</label>
                        <span asp-validation-for="Input.Address" class="text-danger"></span>
                    </div>

                    <div class="form-floating">
                        <input type="date"
                               asp-for="Input.DateOfBirth"
                               class="form-control"
                               placeholder="Date of Birth" />
                        <label asp-for="Input.DateOfBirth">Date of Birth</label>
                        <span asp-validation-for="Input.DateOfBirth" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.ProfileImage" class="form-label">
                            Profile Image
                        </label>

                        <input type="file"
                               accept="image/*"
                               asp-for="Input.ProfileImage"
                               class="form-control auth-file-input" />

                        <span asp-validation-for="Input.ProfileImage" class="text-danger"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="w-100 btn btn-primary">
                        Create Account
                    </button>

                    <div class="auth-links text-center">
                        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">
                            Already have an account? Log in
                        </a>
                    </div>

                    <div class="auth-small-note">
                        Your profile image and account details can be updated later from your profile page.
                    </div>
                </form>
            </div>

        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}