@model ModernArtPrints.Models.Discount

@{
    ViewData["Title"] = "Discount Details";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">
            <i class="fas fa-percent"></i> Discount Details
        </h2>
        <div>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
                <i class="fas fa-edit"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <!-- Details Card -->
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="fas fa-info-circle"></i> Discount Information</h5>
        </div>
        <div class="card-body p-4">
            <div class="row align-items-start">

                <!-- Status Section -->
                <div class="col-lg-4 col-md-5 col-12 mb-4 mb-md-0">
                    <div class="img-wrapper shadow-sm rounded overflow-hidden bg-light d-flex align-items-center justify-content-center"
                         style="min-height: 280px;">
                        <div class="text-center">
                            @if (Model.IsActive && Model.EndDate > DateTime.Now)
                            {
                                <span class="badge bg-success fs-3 px-4 py-3">
                                    <i class="fas fa-check-circle me-2"></i>Active
                                </span>
                            }
                            else if (Model.EndDate < DateTime.Now)
                            {
                                <span class="badge bg-secondary fs-3 px-4 py-3">
                                    <i class="fas fa-clock me-2"></i>Expired
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark fs-3 px-4 py-3">
                                    <i class="fas fa-pause-circle me-2"></i>Inactive
                                </span>
                            }
                            <div class="mt-3 text-muted">
                                <small>Valid: @Model.StartDate.ToString("MMM dd, yyyy") - @Model.EndDate.ToString("MMM dd, yyyy")</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Details Section -->
                <div class="col-lg-8 col-md-7 col-12">

                    <!-- Discount Code -->
                    <div class="detail-item mb-4 pb-3 border-bottom">
                        <h6 class="text-uppercase text-muted fw-bold mb-2 fs-6">
                            <i class="fas fa-ticket-alt me-2"></i>Discount Code
                        </h6>
                        <h3 class="fw-bold text-dark mb-0 font-monospace">@Model.Code</h3>
                    </div>

                    <!-- Value -->
                    <div class="detail-item mb-4 pb-3 border-bottom">
                        <h6 class="text-uppercase text-muted fw-bold mb-2 fs-6">
                            <i class="fas fa-tag me-2"></i>Value
                        </h6>
                        <p class="text-secondary fs-5 mb-0">
                            @if (Model.DiscountType == DiscountType.Percentage)
                            {
                                <span class="badge bg-info text-dark fs-5">@Model.Value%</span>
                                <span class="text-muted ms-2">Percentage</span>
                            }
                            else if (Model.DiscountType == DiscountType.FixedAmount)
                            {
                                <span class="badge bg-primary fs-5">$@Model.Value</span>
                                <span class="text-muted ms-2">Fixed Amount</span>
                            }
                            else if (Model.DiscountType == DiscountType.FreeShipping)
                            {
                                <span class="badge bg-success fs-5">Free Shipping</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary fs-5">No Discount</span>
                            }
                        </p>
                    </div>

                    <!-- Minimum Order Amount -->
                    <div class="detail-item mb-4 pb-3 border-bottom">
                        <h6 class="text-uppercase text-muted fw-bold mb-2 fs-6">
                            <i class="fas fa-shopping-cart me-2"></i>Minimum Order Amount
                        </h6>
                        <p class="text-secondary fs-5 mb-0">
                            @(Model.MinimumOrderAmount > 0 ? $"${Model.MinimumOrderAmount}" : "No minimum required")
                        </p>
                    </div>

                    <!-- Valid Period -->
                    <div class="detail-item mb-4 pb-3 border-bottom">
                        <h6 class="text-uppercase text-muted fw-bold mb-2 fs-6">
                            <i class="fas fa-calendar-alt me-2"></i>Valid Period
                        </h6>
                        <p class="text-secondary fs-5 mb-0">
                            <span class="badge bg-light text-dark border">
                                <i class="far fa-calendar me-1"></i>
                                @Model.StartDate.ToString("MMM dd, yyyy")
                            </span>
                            <span class="mx-2 text-muted">→</span>
                            <span class="badge bg-light text-dark border">
                                <i class="far fa-calendar-check me-1"></i>
                                @Model.EndDate.ToString("MMM dd, yyyy")
                            </span>
                        </p>
                    </div>

                    <!-- Created At -->
                    <div class="detail-item mb-4">
                        <h6 class="text-uppercase text-muted fw-bold mb-2 fs-6">
                            <i class="fas fa-calendar-alt me-2"></i>Created Date
                        </h6>
                        <p class="text-secondary fs-5 mb-0">
                            <span class="badge bg-light text-dark border">
                                <i class="far fa-clock me-1"></i>
                                @Model.CreatedAt.ToString("MMM dd, yyyy - hh:mm tt")
                            </span>
                        </p>
                    </div>

                    <!-- Action Buttons (Mobile visible) -->
                    <div class="d-md-none mt-4 pt-3 border-top">
                        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning w-100 mb-2">
                            <i class="fas fa-edit"></i> Edit Discount
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </a>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>