@model ModernArtPrints.Models.Discount

@{
    ViewData["Title"] = "Delete Discount";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-danger">Delete Discount</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Discounts</a></li>
                    <li class="breadcrumb-item active text-danger">Delete Discount</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>

    <!-- Warning Alert -->
    <div class="alert alert-danger d-flex align-items-center shadow-sm mb-4 border-0" role="alert">
        <i class="fas fa-exclamation-triangle fa-lg me-3"></i>
        <div>
            <strong>Warning:</strong> This action cannot be undone. All associated orders may be affected.
        </div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="row g-4">
            <!-- Left Column: General Information -->
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 overflow-hidden">
                    <div class="card-header bg-dark text-white py-3 px-4">
                        <h5 class="mb-0 fw-semibold"><i class="fas fa-info-circle me-2"></i>General Information</h5>
                    </div>
                    <div class="card-body p-0">
                        <!-- Code Field -->
                        <div class="row g-0 border-bottom">
                            <div class="col-md-4 bg-light p-4">
                                <span class="fw-bold text-dark mb-1 d-block">Code</span>
                                <small class="text-muted">The unique discount code.</small>
                            </div>
                            <div class="col-md-8 p-4 d-flex align-items-center">
                                <span class="fs-5 text-secondary font-monospace">@Model.Code</span>
                            </div>
                        </div>

                        <!-- Value Field -->
                        <div class="row g-0 border-bottom">
                            <div class="col-md-4 bg-light p-4">
                                <span class="fw-bold text-dark mb-1 d-block">Value</span>
                                <small class="text-muted">The discount amount or percentage.</small>
                            </div>
                            <div class="col-md-8 p-4 d-flex align-items-center">
                                <span class="fs-5 text-secondary">
                                    @if (Model.DiscountType == DiscountType.Percentage)
                                    {
                                        <span class="badge bg-info text-dark">@Model.Value%</span>
                                    }
                                    else if (Model.DiscountType == DiscountType.FixedAmount)
                                    {
                                        <span class="badge bg-primary">$@Model.Value</span>
                                    }
                                    else if (Model.DiscountType == DiscountType.FreeShipping)
                                    {
                                        <span class="badge bg-success">Free Shipping</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No Discount</span>
                                    }
                                </span>
                            </div>
                        </div>

                        <!-- Minimum Order Amount Field -->
                        <div class="row g-0 border-bottom">
                            <div class="col-md-4 bg-light p-4">
                                <span class="fw-bold text-dark mb-1 d-block">Minimum Order</span>
                                <small class="text-muted">Minimum cart total required.</small>
                            </div>
                            <div class="col-md-8 p-4 d-flex align-items-center">
                                <span class="fs-5 text-secondary">
                                    @(Model.MinimumOrderAmount > 0 ? $"${Model.MinimumOrderAmount}" : "No minimum required")
                                </span>
                            </div>
                        </div>

                        <!-- Discount Type Field -->
                        <div class="row g-0 border-bottom">
                            <div class="col-md-4 bg-light p-4">
                                <span class="fw-bold text-dark mb-1 d-block">Discount Type</span>
                                <small class="text-muted">How the discount is applied.</small>
                            </div>
                            <div class="col-md-8 p-4 d-flex align-items-center">
                                <span class="fs-5 text-secondary">@Model.DiscountType</span>
                            </div>
                        </div>

                        <!-- Valid Period Field -->
                        <div class="row g-0 border-bottom">
                            <div class="col-md-4 bg-light p-4">
                                <span class="fw-bold text-dark mb-1 d-block">Valid Period</span>
                                <small class="text-muted">When this discount is active.</small>
                            </div>
                            <div class="col-md-8 p-4 d-flex align-items-center">
                                <span class="badge bg-light text-dark border fs-6">
                                    <i class="far fa-calendar me-2"></i>@Model.StartDate.ToString("MMM dd, yyyy")
                                </span>
                                <span class="mx-2 text-muted">→</span>
                                <span class="badge bg-light text-dark border fs-6">
                                    <i class="far fa-calendar-check me-2"></i>@Model.EndDate.ToString("MMM dd, yyyy")
                                </span>
                            </div>
                        </div>

                        <!-- Status Field -->
                        <div class="row g-0 border-bottom">
                            <div class="col-md-4 bg-light p-4">
                                <span class="fw-bold text-dark mb-1 d-block">Status</span>
                                <small class="text-muted">Whether this discount is active.</small>
                            </div>
                            <div class="col-md-8 p-4 d-flex align-items-center">
                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success fs-6"><i class="fas fa-check-circle me-1"></i>Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary fs-6"><i class="fas fa-times-circle me-1"></i>Inactive</span>
                                }
                            </div>
                        </div>

                        <!-- Created Date Field -->
                        <div class="row g-0">
                            <div class="col-md-4 bg-light p-4">
                                <span class="fw-bold text-dark mb-1 d-block">Created Date</span>
                                <small class="text-muted">When this discount was added.</small>
                            </div>
                            <div class="col-md-8 p-4 d-flex align-items-center">
                                <span class="badge bg-light text-dark border fs-6">
                                    <i class="far fa-clock me-2"></i>@Model.CreatedAt.ToString("MMM dd, yyyy - hh:mm tt")
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Delete Button -->
                    <div class="card-footer bg-white border-top-0 p-4 d-flex justify-content-between align-items-center">
                        
                        <div class="btn-group">
                            <button type="submit" class="btn btn-danger rounded-pill px-5 py-2 fw-semibold"
                                    onclick="return confirm('FINAL CONFIRMATION: Permanently delete discount @Model.Code?');">
                                <i class="fas fa-trash-alt me-2"></i>Yes, Delete
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2 ms-2">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            
        </div>
    </form>
</div>