@model ModernArtPrints.Models.Discount

@{
    ViewData["Title"] = "Create Discount";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 520px; border-radius: 16px;">

        <div class="card-header bg-white border-0 pt-4 pb-0">
            <h3 class="fw-bold mb-1">Create Discount</h3>
            <p class="text-muted small mb-0">
                Add a new discount to your store
            </p>
        </div>

        <div class="card-body p-4">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <!-- Discount Code -->
                <div class="mb-3">
                    <label asp-for="Code" class="form-label fw-semibold"></label>
                    <input asp-for="Code"
                           class="form-control form-control-sm"
                           placeholder="Enter discount code" />
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>

                <!-- Value -->
                <div class="mb-3">
                    <label asp-for="Value" class="form-label fw-semibold"></label>
                    <input asp-for="Value"
                           class="form-control form-control-sm"
                           placeholder="Enter discount value" />
                    <span asp-validation-for="Value" class="text-danger small"></span>
                </div>

                <!-- Minimum Order Amount -->
                <div class="mb-3">
                    <label asp-for="MinimumOrderAmount" class="form-label fw-semibold"></label>
                    <input asp-for="MinimumOrderAmount"
                           class="form-control form-control-sm"
                           placeholder="Minimum order amount" />
                    <span asp-validation-for="MinimumOrderAmount" class="text-danger small"></span>
                </div>

                <!-- Discount Type -->
                <div class="mb-3">
                    <label asp-for="DiscountType" class="form-label fw-semibold"></label>
                    <select asp-for="DiscountType" class="form-select form-select-sm">
                        <option value="Percentage">Percentage (%)</option>
                        <option value="FixedAmount">Fixed Amount ($)</option>
                        <option value="FreeShipping">Free Shipping</option>
                        <option value="NoDiscount">No Discount</option>
                    </select>
                    <span asp-validation-for="DiscountType" class="text-danger small"></span>
                </div>

                <!-- Start Date -->
                <div class="mb-3">
                    <label asp-for="StartDate" class="form-label fw-semibold"></label>
                    <input asp-for="StartDate"
                           class="form-control form-control-sm" />
                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                </div>

                <!-- End Date -->
                <div class="mb-3">
                    <label asp-for="EndDate" class="form-label fw-semibold"></label>
                    <input asp-for="EndDate"
                           class="form-control form-control-sm" />
                    <span asp-validation-for="EndDate" class="text-danger small"></span>
                </div>

                <!-- Is Active -->
                <div class="mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="IsActive" />
                        <label class="form-check-label fw-semibold" asp-for="IsActive"></label>
                    </div>
                    <span asp-validation-for="IsActive" class="text-danger small"></span>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-between align-items-center">

                    <a asp-action="Index" class="btn btn-light btn-sm px-4">
                        Back
                    </a>

                    <button type="submit" class="btn btn-dark btn-sm px-4">
                        Create
                    </button>

                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}