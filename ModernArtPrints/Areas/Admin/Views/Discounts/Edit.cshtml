@model ModernArtPrints.Models.Discount

@{
    ViewData["Title"] = "Edit Discount";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-5">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
        <div>
            <h2 class="fw-bold mb-0 text-dark">Discount Settings</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Discounts</a></li>
                    <li class="breadcrumb-item active">Edit Discount</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            <!-- Left Side: Main Form Table -->
            <div class="col-xl-8">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="card-header bg-dark py-3">
                        <h5 class="card-title mb-0 text-white"><i class="bi bi-info-circle me-2"></i>General Information</h5>
                    </div>
                    <div class="card-body p-0">
                        <table class="table align-middle mb-0">
                            <tbody>
                                <tr class="border-bottom">
                                    <th scope="row" class="bg-light ps-4 py-4" width="30%">
                                        <label asp-for="Code" class="h6 mb-0 fw-bold"></label>
                                        <div class="small text-muted fw-normal mt-1">The unique code customers enter at checkout.</div>
                                    </th>
                                    <td class="pe-4">
                                        <input asp-for="Code" class="form-control form-control-lg border-0 shadow-none" placeholder="e.g. SUMMER20" />
                                        <span asp-validation-for="Code" class="text-danger small ms-2"></span>
                                    </td>
                                </tr>
                                <tr class="border-bottom">
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <label asp-for="Value" class="h6 mb-0 fw-bold"></label>
                                        <div class="small text-muted fw-normal mt-1">The discount amount or percentage.</div>
                                    </th>
                                    <td class="pe-4">
                                        <input asp-for="Value" class="form-control form-control-lg border-0 shadow-none" placeholder="e.g. 20" />
                                        <span asp-validation-for="Value" class="text-danger small ms-2"></span>
                                    </td>
                                </tr>
                                <tr class="border-bottom">
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <label asp-for="MinimumOrderAmount" class="h6 mb-0 fw-bold"></label>
                                        <div class="small text-muted fw-normal mt-1">Minimum cart total required to use this discount.</div>
                                    </th>
                                    <td class="pe-4">
                                        <input asp-for="MinimumOrderAmount" class="form-control form-control-lg border-0 shadow-none" placeholder="e.g. 50.00" />
                                        <span asp-validation-for="MinimumOrderAmount" class="text-danger small ms-2"></span>
                                    </td>
                                </tr>
                                <tr class="border-bottom">
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <label asp-for="DiscountType" class="h6 mb-0 fw-bold"></label>
                                        <div class="small text-muted fw-normal mt-1">How the discount value is applied.</div>
                                    </th>
                                    <td class="pe-4">
                                        <select asp-for="DiscountType" class="form-select form-select-lg border-0 shadow-none">
                                            <option value="Percentage">Percentage (%)</option>
                                            <option value="FixedAmount">Fixed Amount ($)</option>
                                            <option value="FreeShipping">Free Shipping</option>
                                            <option value="NoDiscount">No Discount</option>
                                        </select>
                                        <span asp-validation-for="DiscountType" class="text-danger small ms-2"></span>
                                    </td>
                                </tr>
                                <tr class="border-bottom">
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <label asp-for="StartDate" class="h6 mb-0 fw-bold"></label>
                                        <div class="small text-muted fw-normal mt-1">When this discount becomes active.</div>
                                    </th>
                                    <td class="pe-4">
                                        <input asp-for="StartDate" class="form-control form-control-lg border-0 shadow-none" />
                                        <span asp-validation-for="StartDate" class="text-danger small ms-2"></span>
                                    </td>
                                </tr>
                                <tr class="border-bottom">
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <label asp-for="EndDate" class="h6 mb-0 fw-bold"></label>
                                        <div class="small text-muted fw-normal mt-1">When this discount expires.</div>
                                    </th>
                                    <td class="pe-4">
                                        <input asp-for="EndDate" class="form-control form-control-lg border-0 shadow-none" />
                                        <span asp-validation-for="EndDate" class="text-danger small ms-2"></span>
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <label asp-for="IsActive" class="h6 mb-0 fw-bold"></label>
                                        <div class="small text-muted fw-normal mt-1">Enable or disable this discount.</div>
                                    </th>
                                    <td class="pe-4">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" asp-for="IsActive" style="width: 3em; height: 1.5em;">
                                        </div>
                                        <span asp-validation-for="IsActive" class="text-danger small ms-2"></span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer bg-white border-top-0 py-4 ps-4">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">
                            <i class="bi bi-save me-2"></i> Save Changes
                        </button>
                    </div>
                </div>
            </div>

            <!-- Right Side: Status & Info -->
            <div class="col-xl-4">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-secondary text-white py-3">
                        <h5 class="card-title mb-0"><i class="bi bi-clock-history me-2"></i>Status</h5>
                    </div>
                    <div class="card-body py-4">
                        <label class="d-block mb-3 fw-bold text-muted text-uppercase small">Created At</label>
                        <div class="text-center mb-4">
                            <span class="badge bg-light text-dark border fs-5 px-4 py-2">
                                <i class="bi bi-calendar me-2"></i>@Model.CreatedAt.ToString("MMM dd, yyyy")
                            </span>
                        </div>

                       
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    .bg-light {
        background-color: #f8f9fa !important;
    }

    .form-control:focus {
        background-color: #fff;
        border-color: #dee2e6;
        box-shadow: none;
    }

    .table > :not(caption) > * > * {
        padding: 1.5rem 0.75rem;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}