@model IEnumerable<ModernArtPrints.Areas.Admin.Controllers.UserViewModel>

@{
    ViewData["Title"] = "Users Management";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1>Users Management</h1>


<!-- Simple Search & Filter -->
<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-md-6">
        <div class="input-group input-group-sm">
            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
            <input type="text" name="searchString" class="form-control form-control-sm"
                   placeholder="Search by name, email, or username..."
                   value="@ViewData["SearchString"]" />
        </div>
    </div>
    <div class="col-md-3">
        <select name="role" class="form-select form-select-sm">
            <option value="">All Roles</option>
            <option value="Admin" selected="@(ViewData["Role"]?.ToString() == "Admin" ? "selected" : null)">Admin</option>
            <option value="User" selected="@(ViewData["Role"]?.ToString() == "User" ? "selected" : null)">User</option>
        </select>
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-dark btn-sm w-100 rounded-pill">
            <i class="bi bi-funnel"></i> Filter
        </button>
    </div>
</form>

<table class="table table-hover align-middle">
    <thead class="thead-dark">
        <tr>
            <th scope="col" class="py-3 ps-4">#</th>
            <th scope="col" class="py-3 text-start">User</th>
            <th scope="col" class="py-3 text-center" width="250px">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="3" class="text-center py-4 text-muted">
                    <i class="bi bi-inbox fs-2 mb-2"></i>
                    <p>No users found.</p>
                </td>
            </tr>
        }
        else
        {
            int count = 1;
            @foreach (var item in Model)
            {
                <tr>
                    <th scope="row" class="ps-4">
                        @count
                    </th>
                    <td class="fw-semibold fs-5 text-start">
                        <div class="d-flex align-items-center">
                            
                            <div>
                                <div class="fw-bold">@item.FullName</div>
                                
                               
                            </div>
                        </div>
                    </td>
                    <td class="text-center">
                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-outline-info btn-sm rounded-pill px-3">
                            <i class="bi bi-eye"></i>
                        </a>
                    </td>
                </tr>
                count++;
            }
        }
    </tbody>
</table>