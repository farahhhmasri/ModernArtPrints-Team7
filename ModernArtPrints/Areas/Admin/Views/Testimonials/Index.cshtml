@model IEnumerable<ModernArtPrints.Models.Testimonial>

@{
    ViewData["Title"] = "Testimonials Moderation";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1>Testimonials Moderation</h1>

<!-- Search & Filter -->
<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-md-5">
        <div class="input-group input-group-sm">
            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
            <input type="text" name="searchString" class="form-control form-control-sm"
                   placeholder="Search by content or user..."
                   value="@ViewData["SearchString"]" />
        </div>
    </div>
    <div class="col-md-4">
        <select name="isApproved" class="form-select form-select-sm">
            <option value="">All Status</option>
            <option value="true" selected="@(ViewData["IsApproved"]?.ToString() == "True" ? "selected" : null)">Approved</option>
            <option value="false" selected="@(ViewData["IsApproved"]?.ToString() == "False" ? "selected" : null)">Pending</option>
        </select>
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-dark btn-sm w-100 rounded-pill">
            <i class="bi bi-funnel"></i> Filter
        </button>
    </div>
</form>

<table class="table table-hover align-middle">
    <thead class="thead-dark">
        <tr>
            <th scope="col" class="py-3 ps-4">#</th>
            <th scope="col" class="py-3 text-start">User</th>
            <th scope="col" class="py-3 text-start">Content</th>
            <th scope="col" class="py-3 text-start">Date</th>
            <th scope="col" class="py-3 text-start">Status</th>
            <th scope="col" class="py-3 text-center" width="250px">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center py-4 text-muted">
                    <i class="bi bi-inbox fs-2 mb-2"></i>
                    <p>No testimonials found.</p>
                </td>
            </tr>
        }
        else
        {
            int count = 1;
            @foreach (var item in Model)
            {
                <tr>
                    <th scope="row" class="ps-4">
                        @count
                    </th>
                    <td class="fw-semibold text-start">
                        <div class="d-flex align-items-center">
                            <div>
                                <div class="fw-bold">@(item.User?.UserName ?? "Unknown")</div>
                            </div>
                        </div>
                    </td>
                    <td class="text-start">
                        @(item.Message?.Length > 100 ? item.Message.Substring(0, 100) + "..." : item.Message ?? "-")
                    </td>
                    <td class="text-start">
                        @item.CreatedAt.ToString("MM/dd/yyyy")
                    </td>
                    <td class="text-start">
                        <span class="badge @(item.IsApproved ? "bg-success" : "bg-warning text-dark")">
                            @(item.IsApproved ? "Approved" : "Pending")
                        </span>
                    </td>
                    <td class="text-center">
                        @if (!item.IsApproved)
                        {
                            <form asp-action="Approve" asp-route-id="@item.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-outline-success btn-sm rounded-pill px-3" title="Approve">
                                    <i class="bi bi-check-lg"></i>
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Reject" asp-route-id="@item.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-outline-warning btn-sm rounded-pill px-3" title="Reject">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </form>
                        }
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Are you sure you want to delete this testimonial?');">
                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3" title="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                count++;
            }
        }
    </tbody>
</table>