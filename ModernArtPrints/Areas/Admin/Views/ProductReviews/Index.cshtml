@using ModernArtPrints.Models
@model IEnumerable<ModernArtPrints.Models.ProductReview>

@{
    ViewData["Title"] = "Product Reviews Moderation";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mb-4">Product Reviews Moderation</h1>

<!-- Search & Filter -->
<form asp-action="Index" method="get" class="row g-2 mb-4">

    <!-- Search -->
    <div class="col-md-4">
        <div class="input-group input-group-sm">
            <span class="input-group-text bg-white">
                <i class="bi bi-search"></i>
            </span>

            <input type="text"
                   name="searchString"
                   class="form-control form-control-sm"
                   placeholder="Search by comment or user..."
                   value="@(ViewData["SearchString"] ?? "")" />
        </div>
    </div>

    <!-- Status Filter -->
    <div class="col-md-3">
        <select name="isApproved" class="form-select form-select-sm">

            <option value="">All Status</option>

            @if (ViewData["IsApproved"]?.ToString() == "True")
            {
                <option value="true" selected>Approved</option>
            }
            else
            {
                <option value="true">Approved</option>
            }

            @if (ViewData["IsApproved"]?.ToString() == "False")
            {
                <option value="false" selected>Pending</option>
            }
            else
            {
                <option value="false">Pending</option>
            }

        </select>
    </div>

    <!-- Product Filter -->
    <div class="col-md-3">
        <select name="productId" class="form-select form-select-sm">

            <option value="">All Products</option>

            @if (ViewBag.Products != null)
            {
                @foreach (var product in ViewBag.Products)
                {
                    if (ViewData["ProductId"]?.ToString() == product.Id.ToString())
                    {
                        <option value="@product.Id" selected>
                            @product.Name
                        </option>
                    }
                    else
                    {
                        <option value="@product.Id">
                            @product.Name
                        </option>
                    }
                }
            }

        </select>
    </div>

    <!-- Button -->
    <div class="col-md-2">
        <button type="submit"
                class="btn btn-dark btn-sm w-100 rounded-pill">
            <i class="bi bi-funnel"></i> Filter
        </button>
    </div>

</form>

<!-- Table -->
<div class="table-responsive">

    <table class="table table-hover align-middle">

        <thead class="table-dark">
            <tr>
                <th class="py-3 ps-4">#</th>
                <th class="py-3">Product</th>
                <th class="py-3">User</th>
                <th class="py-3">Rating</th>
                <th class="py-3">Comment</th>
                <th class="py-3">Date</th>
                <th class="py-3">Status</th>
                <th class="py-3 text-center" width="250px">Actions</th>
            </tr>
        </thead>

        <tbody>

            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="8" class="text-center py-5 text-muted">

                        <i class="bi bi-inbox fs-1 d-block mb-3"></i>

                        <p class="mb-0">No reviews found.</p>

                    </td>
                </tr>
            }
            else
            {
                int count = 1;

                @foreach (var item in Model)
                {
                    <tr>

                        <!-- Count -->
                        <th scope="row" class="ps-4">
                            @count
                        </th>

                        <!-- Product -->
                        <td class="fw-semibold">
                            @(item.Product?.Name ?? "Unknown")
                        </td>

                        <!-- User -->
                        <td>
                            @(item.User?.UserName ?? "Unknown")
                        </td>

                        <!-- Rating -->
                        <td>

                            @for (int i = 0; i < item.Rating; i++)
                            {
                                <i class="bi bi-star-fill text-warning"></i>
                            }

                            @for (int i = item.Rating; i < 5; i++)
                            {
                                <i class="bi bi-star text-warning"></i>
                            }

                        </td>

                        <!-- Comment -->
                        <td>

                            @if (!string.IsNullOrEmpty(item.CommentText))
                            {
                                @(item.CommentText.Length > 80
                                                    ? item.CommentText.Substring(0, 80) + "..."
                                                    : item.CommentText)
                                        }
                            else
                            {
                                <span>-</span>
                            }

                        </td>

                        <!-- Date -->
                        <td>
                            @item.CreatedAt.ToString("MM/dd/yyyy")
                        </td>

                        <!-- Status -->
                        <td>

                            @if (item.IsApproved)
                            {
                                <span class="badge bg-success">
                                    Approved
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    Pending
                                </span>
                            }

                        </td>

                        <!-- Actions -->
                        <td class="text-center">

                            @if (!item.IsApproved)
                            {
                                <form asp-action="Approve"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      class="d-inline">

                                    <button type="submit"
                                            class="btn btn-outline-success btn-sm rounded-pill px-3"
                                            title="Approve">

                                        <i class="bi bi-check-lg"></i>

                                    </button>

                                </form>
                            }
                            else
                            {
                                <form asp-action="Reject"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      class="d-inline">

                                    <button type="submit"
                                            class="btn btn-outline-warning btn-sm rounded-pill px-3"
                                            title="Reject">

                                        <i class="bi bi-x-lg"></i>

                                    </button>

                                </form>
                            }

                            <!-- Delete -->
                            <form asp-action="Delete"
                                  asp-route-id="@item.Id"
                                  method="post"
                                  class="d-inline"
                                  onsubmit="return confirm('Are you sure you want to delete this review?');">

                                <button type="submit"
                                        class="btn btn-outline-danger btn-sm rounded-pill px-3"
                                        title="Delete">

                                    <i class="bi bi-trash"></i>

                                </button>

                            </form>

                        </td>

                    </tr>

                    count++;
                }
            }

        </tbody>

    </table>

</div>