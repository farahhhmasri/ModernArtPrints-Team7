@model IEnumerable<ModernArtPrints.Models.Category>

@{
    ViewData["Title"] = "Categories Management";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Categories Management</h1>

    <a asp-action="Create"
       class="btn btn-dark rounded-pill px-4">
        <i class="bi bi-plus-circle me-1"></i>
        Create New
    </a>
</div>

<!-- Search -->
<form asp-action="Index" method="get" class="row g-2 mb-4">

    <div class="col-md-10">
        <div class="input-group input-group-sm">

            <span class="input-group-text bg-white">
                <i class="bi bi-search"></i>
            </span>

            <input type="text"
                   name="searchString"
                   class="form-control form-control-sm"
                   placeholder="Search by category name..."
                   value="@ViewData["SearchString"]" />

        </div>
    </div>

    <div class="col-md-2">
        <button type="submit"
                class="btn btn-dark btn-sm w-100 rounded-pill">

            <i class="bi bi-funnel"></i> Search

        </button>
    </div>

</form>

<!-- Table -->
<div class="table-responsive">

    <table class="table table-hover align-middle">

        <thead class="table-dark">
            <tr>
                <th scope="col" class="py-3 ps-4">#</th>
                <th scope="col" class="py-3 text-start">
                    Category Name
                </th>
                <th scope="col"
                    class="py-3 text-center"
                    width="250px">

                    Actions

                </th>
            </tr>
        </thead>

        <tbody>

            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="3"
                        class="text-center py-5 text-muted">

                        <i class="bi bi-inbox fs-1 d-block mb-3"></i>

                        <p class="mb-0">
                            No categories found.
                        </p>

                    </td>
                </tr>
            }
            else
            {
                int count = 1;

                @foreach (var item in Model)
                {
                    <tr>

                        <!-- Counter -->
                        <th scope="row" class="ps-4">
                            @count
                        </th>

                        <!-- Category Name -->
                        <td class="fw-semibold fs-6 text-start">

                            <div class="d-flex align-items-center">

                               

                                <div>

                                    <div class="fw-bold">
                                        @item.Name
                                    </div>

                                </div>

                            </div>

                        </td>

                        <!-- Actions -->
                        <td class="text-center">

                            <!-- Edit -->
                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-warning btn-sm rounded-pill px-3"
                               title="Edit">

                                <i class="bi bi-pencil-square"></i>

                            </a>

                            <!-- Details -->
                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-info btn-sm rounded-pill px-3"
                               title="Details">

                                <i class="bi bi-eye"></i>

                            </a>

                            <!-- Delete -->
                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-danger btn-sm rounded-pill px-3"
                               title="Delete">

                                <i class="bi bi-trash"></i>

                            </a>

                        </td>

                    </tr>

                    count++;
                }
            }

        </tbody>

    </table>

</div>