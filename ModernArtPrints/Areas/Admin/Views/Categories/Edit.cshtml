@using ModernArtPrints.Areas.Admin.Models
@model ModernArtPrints.Areas.Admin.Models.CategoryEditViewModel

@{
    ViewData["Title"] = "Edit Category";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-5">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
        <div>
            <h2 class="fw-bold mb-0 text-dark">Category Settings</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Categories</a></li>
                    <li class="breadcrumb-item active">Edit Category</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <form asp-action="Edit" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ExistingImageUrl" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            <!-- Left Side: Main Form Table -->
            <div class="col-xl-8">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="card-header bg-dark py-3">
                        <h5 class="card-title mb-0 text-white"><i class="bi bi-info-circle me-2"></i>General Information</h5>
                    </div>
                    <div class="card-body p-0">
                        <table class="table align-middle mb-0">
                            <tbody>
                                <tr class="border-bottom">
                                    <th scope="row" class="bg-light ps-4 py-4" width="30%">
                                        <label asp-for="Name" class="h6 mb-0 fw-bold"></label>
                                        <div class="small text-muted fw-normal mt-1">The public name of the category.</div>
                                    </th>
                                    <td class="pe-4">
                                        <input asp-for="Name" class="form-control form-control-lg border-0 shadow-none" placeholder="e.g. Abstract Art" />
                                        <span asp-validation-for="Name" class="text-danger small ms-2"></span>
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <label asp-for="Description" class="h6 mb-0 fw-bold"></label>
                                        <div class="small text-muted fw-normal mt-1">A brief summary of the collection.</div>
                                    </th>
                                    <td class="pe-4">
                                        <textarea asp-for="Description" class="form-control border-0 shadow-none" rows="4" placeholder="Describe this category..."></textarea>
                                        <span asp-validation-for="Description" class="text-danger small ms-2"></span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer bg-white border-top-0 py-4 ps-4">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">
                            <i class="bi bi-save me-2"></i> Save Changes
                        </button>
                    </div>
                </div>
            </div>

            <!-- Right Side: Image & Media Management -->
            <div class="col-xl-4">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-secondary text-white py-3">
                        <h5 class="card-title mb-0"><i class="bi bi-image me-2"></i>Media</h5>
                    </div>
                    <div class="card-body text-center py-4">
                        <label class="d-block mb-3 fw-bold text-muted text-uppercase small">Currently Displayed</label>
                        <div class="position-relative d-inline-block mb-4">
                            <img src="~/uploads/@Model.ExistingImageUrl"
                                 class="img-thumbnail shadow-sm"
                                 style="width: 180px; height: 180px; object-fit: cover; border-radius: 12px;"
                                 alt="Current Category Image" />
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-success border border-light">
                                Active
                            </span>
                        </div>

                        <div class="text-start mt-2">
                            <label class="form-label fw-bold">Update Artwork</label>
                            <input asp-for="NewImageFile" type="file" class="form-control" id="customFile" />
                            <div class="form-text mt-2">
                                <i class="bi bi-info-circle-fill me-1"></i> Recommended: 800x800px (JPG, PNG)
                            </div>
                        </div>
                    </div>
                </div>

                
            </div>
        </div>
    </form>
</div>

<style>
    /* Professional subtle adjustments */
    .bg-light {
        background-color: #f8f9fa !important;
    }

    .form-control:focus {
        background-color: #fff;
        border-color: #dee2e6;
        box-shadow: none;
    }

    .table > :not(caption) > * > * {
        padding: 1.5rem 0.75rem;
    }
</style>