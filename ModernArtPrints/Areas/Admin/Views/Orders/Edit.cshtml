@using ModernArtPrints.Models
@model ModernArtPrints.Models.Order

@{
    ViewData["Title"] = "Edit Order Status";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-5">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
        <div>
            <h2 class="fw-bold mb-0 text-dark">Order Settings</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Orders</a></li>
                    <li class="breadcrumb-item active">Edit Order Status</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <form asp-action="Edit">
       
       
        <input type="hidden" asp-for="OrderDate" />
        <input type="hidden" asp-for="TotalAmount" />
        <input type="hidden" asp-for="DiscountAmount" />
        <input type="hidden" asp-for="DiscountId" />
        <input type="hidden" asp-for="PaymentStatus" />
        <input type="hidden" asp-for="ShippingAddress" />
        <input type="hidden" asp-for="PhoneNumber" />
        <input type="hidden" asp-for="UpdatedAt" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4 justify-content-center">
            <div class="col-xl-6">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="card-header bg-dark py-3">
                        <h5 class="card-title mb-0 text-white">
                            <i class="bi bi-info-circle me-2"></i>Order Information
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <table class="table align-middle mb-0">
                            <tbody>
                                
                                    
                           

                                <!-- Order Date (Read-only) -->
                                <tr class="border-bottom">
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <span class="h6 mb-0 fw-bold">Order Date</span>
                                        <div class="small text-muted fw-normal mt-1">When the order was placed.</div>
                                    </th>
                                    <td class="pe-4">
                                        <span class="text-muted">
                                            <i class="bi bi-calendar me-1"></i> @Model.OrderDate.ToString("MM/dd/yyyy HH:mm")
                                        </span>
                                    </td>
                                </tr>

                                <!-- Total Amount (Read-only) -->
                                <tr class="border-bottom">
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <span class="h6 mb-0 fw-bold">Total Amount</span>
                                        <div class="small text-muted fw-normal mt-1">Order total including discounts.</div>
                                    </th>
                                    <td class="pe-4">
                                        <span class="fw-bold fs-5 text-success">$@Model.TotalAmount.ToString("F2")</span>
                                        @if (Model.DiscountAmount > 0)
                                        {
                                            <span class="badge bg-warning text-dark ms-2">
                                                <i class="bi bi-tag me-1"></i> -$@Model.DiscountAmount.ToString("F2")
                                            </span>
                                        }
                                    </td>
                                </tr>

                                <!-- Current Status (Read-only display) -->
                                <tr class="border-bottom">
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <span class="h6 mb-0 fw-bold">Current Status</span>
                                        <div class="small text-muted fw-normal mt-1">Present order state.</div>
                                    </th>
                                    <td class="pe-4">
                                        <span class="badge @GetOrderStatusBadgeClass(Model.OrderStatus) fs-6 px-3 py-2">
                                            <i class="bi @GetOrderStatusIcon(Model.OrderStatus) me-1"></i> @Model.OrderStatus
                                        </span>
                                    </td>
                                </tr>

                                <!-- Payment Status (Read-only) -->
                                <tr class="border-bottom">
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <span class="h6 mb-0 fw-bold">Payment Status</span>
                                        <div class="small text-muted fw-normal mt-1">Current payment state.</div>
                                    </th>
                                    <td class="pe-4">
                                        <span class="badge @GetPaymentStatusBadgeClass(Model.PaymentStatus) fs-6 px-3 py-2">
                                            <i class="bi @GetPaymentStatusIcon(Model.PaymentStatus) me-1"></i> @Model.PaymentStatus
                                        </span>
                                    </td>
                                </tr>

                                <!-- Shipping Address (Read-only) -->
                                <tr class="border-bottom">
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <span class="h6 mb-0 fw-bold">Shipping Address</span>
                                        <div class="small text-muted fw-normal mt-1">Delivery destination.</div>
                                    </th>
                                    <td class="pe-4">
                                        <span class="text-muted">
                                            <i class="bi bi-geo-alt me-1"></i> @(Model.ShippingAddress ?? "Not provided")
                                        </span>
                                    </td>
                                </tr>

                                <!-- Phone Number (Read-only) -->
                                <tr class="border-bottom">
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <span class="h6 mb-0 fw-bold">Phone Number</span>
                                        <div class="small text-muted fw-normal mt-1">Contact number for delivery.</div>
                                    </th>
                                    <td class="pe-4">
                                        <span class="text-muted">
                                            <i class="bi bi-telephone me-1"></i> @(Model.PhoneNumber ?? "Not provided")
                                        </span>
                                    </td>
                                </tr>

                                <!-- EDITABLE: Order Status -->
                                <tr>
                                    <th scope="row" class="bg-light ps-4 py-4">
                                        <label asp-for="OrderStatus" class="h6 mb-0 fw-bold"></label>
                                        <div class="small text-muted fw-normal mt-1">Change the order state.</div>
                                    </th>
                                    <td class="pe-4">
                                        <select asp-for="OrderStatus"
                                                asp-items="Html.GetEnumSelectList<OrderStatus>()"
                                                class="form-select form-select-lg border-0 shadow-none bg-white">
                                        </select>
                                        <span asp-validation-for="OrderStatus" class="text-danger small ms-2"></span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer bg-white border-top-0 py-4 ps-4">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">
                            <i class="bi bi-save me-2"></i> Save Changes
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    .bg-light {
        background-color: #f8f9fa !important;
    }

    .form-select:focus {
        background-color: #fff;
        border-color: #dee2e6;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }

    .table > :not(caption) > * > * {
        padding: 1.5rem 0.75rem;
    }
</style>

@functions {
    string GetOrderStatusBadgeClass(OrderStatus status) => status switch
    {
        OrderStatus.delivered => "bg-success",
        OrderStatus.processing => "bg-warning text-dark",
        OrderStatus.shipped => "bg-info text-dark",
        OrderStatus.cancelled => "bg-danger",
        _ => "bg-secondary"
    };

    string GetOrderStatusIcon(OrderStatus status) => status switch
    {
        OrderStatus.delivered => "bi-check-circle-fill",
        OrderStatus.processing => "bi-gear-fill",
        OrderStatus.shipped => "bi-truck",
        OrderStatus.cancelled => "bi-x-circle-fill",
        _ => "bi-question-circle"
    };

    string GetPaymentStatusBadgeClass(PaymentStatus status) => status switch
    {
        PaymentStatus.Success => "bg-success",
        PaymentStatus.Pending => "bg-warning text-dark",
        PaymentStatus.Failed => "bg-danger",
       
        _ => "bg-secondary"
    };

    string GetPaymentStatusIcon(PaymentStatus status) => status switch
    {
        PaymentStatus.Success => "bi-credit-card-2-front-fill",
        PaymentStatus.Pending => "bi-hourglass-split",
        PaymentStatus.Failed => "bi-x-octagon-fill",
      
        _ => "bi-question-circle"
    };
}