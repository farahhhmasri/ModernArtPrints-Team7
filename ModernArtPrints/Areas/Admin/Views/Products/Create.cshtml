@using ModernArtPrints.Areas.Admin.Models

@model ModernArtPrints.Areas.Admin.Models.ProductCreateViewModel

@{
    ViewData["Title"] = "Create Product";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 520px; border-radius: 16px;">

        <div class="card-header bg-white border-0 pt-4 pb-0">
            <h3 class="fw-bold mb-1">Create Product</h3>
            <p class="text-muted small mb-0">
                Add a new product to your store
            </p>
        </div>

        <div class="card-body p-4">

            <form asp-action="Create" enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <!-- Product Name -->
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name"
                           class="form-control form-control-sm"
                           placeholder="Enter product name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <!-- Description -->
                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description"
                              class="form-control form-control-sm"
                              rows="3"
                              placeholder="Short product description"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <!-- Price -->
                <div class="mb-3">
                    <label asp-for="Price" class="form-label fw-semibold"></label>
                    <input asp-for="Price"
                           class="form-control form-control-sm"
                           placeholder="Enter price" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <!-- Discount -->
                <div class="mb-3">
                    <label asp-for="DiscountId" class="form-label fw-semibold">Discount</label>
                    <select asp-for="DiscountId" class="form-select form-select-sm" asp-items='@ViewBag.DiscountId'>
                        <option value="">-- Select Discount --</option>
                    </select>
                    <span asp-validation-for="DiscountId" class="text-danger small"></span>
                </div>

                <!-- Stock Quantity -->
                <div class="mb-3">
                    <label asp-for="StockQuantity" class="form-label fw-semibold"></label>
                    <input asp-for="StockQuantity"
                           class="form-control form-control-sm"
                           placeholder="Enter stock quantity" />
                    <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                </div>

                <!-- Category -->
                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label fw-semibold">Category</label>
                    <select asp-for="CategoryId" class="form-select form-select-sm" asp-items="@ViewBag.CategoryId">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>

                <!-- Is Active -->
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="IsActive" />
                        <label class="form-check-label fw-semibold" asp-for="IsActive"></label>
                    </div>
                    <span asp-validation-for="IsActive" class="text-danger small"></span>
                </div>

                <!-- Main Image Upload -->
                <div class="mb-3">
                    <label asp-for="MainImageFile" class="form-label fw-semibold">
                        Main Product Image
                    </label>
                    <input asp-for="MainImageFile"
                           type="file"
                           class="form-control form-control-sm" />
                    <span asp-validation-for="MainImageFile" class="text-danger small"></span>
                </div>

                <!-- Additional Images Upload -->
                <div class="mb-4">
                    <label asp-for="AdditionalImages" class="form-label fw-semibold">
                        Additional Product Images
                    </label>
                    <input asp-for="AdditionalImages"
                           type="file"
                           multiple
                           class="form-control form-control-sm" />
                    <div class="form-text text-muted small">
                        You can select multiple images
                    </div>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-between align-items-center">

                    <a asp-action="Index" class="btn btn-light btn-sm px-4">
                        Back
                    </a>

                    <button type="submit" class="btn btn-dark btn-sm px-4">
                        Create
                    </button>

                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}