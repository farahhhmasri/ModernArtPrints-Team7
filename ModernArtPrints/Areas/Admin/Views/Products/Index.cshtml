@model IEnumerable<ModernArtPrints.Models.Product>

@{
    ViewData["Title"] = "Products";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}


<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Products Management</h1>

    <a asp-action="Create"
       class="btn btn-dark rounded-pill px-4">
        <i class="bi bi-plus-circle me-1"></i>
        Create New
    </a>
</div>
<!-- Search -->
<form asp-action="Index" method="get" class="row g-2 mb-4">

    <div class="col-md-10">
        <div class="input-group input-group-sm">

            <span class="input-group-text bg-white">
                <i class="bi bi-search"></i>
            </span>

            <input type="text"
                   name="searchString"
                   class="form-control form-control-sm"
                   placeholder="Search by product name..."
                   value="@ViewData["SearchString"]" />

        </div>
    </div>

    <div class="col-md-2">
        <button type="submit"
                class="btn btn-dark btn-sm w-100 rounded-pill">

            <i class="bi bi-funnel"></i> Search

        </button>
    </div>

</form>
<table class="table table-hover align-middle">
    <thead class="thead-dark">
        <tr>
            <th scope="col" class="py-3 ps-4">#</th>
            <th scope="col" class="py-3 text-start">Product Name</th>
            <th scope="col" class="py-3 text-center" width="250px">Actions</th>
        </tr>
    </thead>
    <tbody>
        @{
            int count = 1;
        }
        @foreach (var item in Model)
        {
            <tr>
                <th scope="row" class="ps-4">
                    @count
                </th>
                <td class="fw-semibold fs-5 text-start">
                    @item.Name
                </td>
                <td class="text-center">
                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-outline-warning btn-sm rounded-pill px-3">
                        <i class="bi bi-pencil-square"></i>
                    </a>

                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-outline-info btn-sm rounded-pill px-3">
                        <i class="bi bi-eye"></i>
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-outline-danger btn-sm rounded-pill px-3">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
            count++;
        }
    </tbody>
</table>