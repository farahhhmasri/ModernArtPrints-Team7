@model ModernArtPrints.Models.Product

@{
    ViewData["Title"] = "Product Details";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">
            <i class="fas fa-box"></i> Product Details
        </h2>
        <div>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
                <i class="fas fa-edit"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <!-- Details Card -->
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="fas fa-info-circle"></i> Product Information</h5>
        </div>
        <div class="card-body p-4">
            <div class="row align-items-start">

                <!-- Image Section -->
                <div class="col-lg-4 col-md-5 col-12 mb-4 mb-md-0">
                    <div class="img-wrapper shadow-sm rounded overflow-hidden bg-light d-flex align-items-center justify-content-center"
                         style="min-height: 280px;">
                        @if (!string.IsNullOrEmpty(Model.MainImageUrl))
                        {
                            <img src="~/uploads/@Model.MainImageUrl"
                                 alt="@Model.Name"
                                 class="img-fluid w-100 object-fit-cover"
                                 style="max-height: 300px;"
                                 onerror="this.onerror=null; this.src='~/images/no-image.png'; this.classList.add('p-4');" />
                        }
                        else
                        {
                            <div class="text-center text-muted py-5">
                                <i class="fas fa-image fa-4x mb-3 opacity-25"></i>
                                <p class="mb-0">No Image Available</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Details Section -->
                <div class="col-lg-8 col-md-7 col-12">

                    <!-- Product Name -->
                    <div class="detail-item mb-4 pb-3 border-bottom">
                        <h6 class="text-uppercase text-muted fw-bold mb-2 fs-6">
                            <i class="fas fa-box me-2"></i>Product Name
                        </h6>
                        <h3 class="fw-bold text-dark mb-0">@Model.Name</h3>
                    </div>

                    <!-- Description -->
                    <div class="detail-item mb-4 pb-3 border-bottom">
                        <h6 class="text-uppercase text-muted fw-bold mb-2 fs-6">
                            <i class="fas fa-align-left me-2"></i>Description
                        </h6>
                        <p class="text-secondary fs-5 mb-0">
                            @(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)
                        </p>
                    </div>

                    <!-- Price -->
                    <div class="detail-item mb-4 pb-3 border-bottom">
                        <h6 class="text-uppercase text-muted fw-bold mb-2 fs-6">
                            <i class="fas fa-dollar-sign me-2"></i>Price
                        </h6>
                        <p class="text-secondary fs-5 mb-0">
                            <span class="badge bg-success fs-5">$@Model.Price</span>
                        </p>
                    </div>

                    <!-- Discount -->
                    <div class="detail-item mb-4 pb-3 border-bottom">
                        <h6 class="text-uppercase text-muted fw-bold mb-2 fs-6">
                            <i class="fas fa-percent me-2"></i>Discount
                        </h6>
                        <p class="text-secondary fs-5 mb-0">
                            @(Model.Discount != null ? Model.Discount.Code : "No discount applied")
                        </p>
                    </div>

                    <!-- Stock Quantity -->
                    <div class="detail-item mb-4 pb-3 border-bottom">
                        <h6 class="text-uppercase text-muted fw-bold mb-2 fs-6">
                            <i class="fas fa-cubes me-2"></i>Stock Quantity
                        </h6>
                        <p class="text-secondary fs-5 mb-0">
                            <span class="badge @(Model.StockQuantity > 10 ? "bg-success" : Model.StockQuantity > 0 ? "bg-warning text-dark" : "bg-danger") fs-5">
                                @Model.StockQuantity in stock
                            </span>
                        </p>
                    </div>

                    <!-- Category -->
                    <div class="detail-item mb-4 pb-3 border-bottom">
                        <h6 class="text-uppercase text-muted fw-bold mb-2 fs-6">
                            <i class="fas fa-folder me-2"></i>Category
                        </h6>
                        <p class="text-secondary fs-5 mb-0">
                            @(Model.Category != null ? Model.Category.Name : "Uncategorized")
                        </p>
                    </div>

                    <!-- Status -->
                    <div class="detail-item mb-4 pb-3 border-bottom">
                        <h6 class="text-uppercase text-muted fw-bold mb-2 fs-6">
                            <i class="fas fa-toggle-on me-2"></i>Status
                        </h6>
                        <p class="text-secondary fs-5 mb-0">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary"><i class="fas fa-times-circle me-1"></i>Inactive</span>
                            }
                        </p>
                    </div>

                    <!-- Created At -->
                    <div class="detail-item mb-4">
                        <h6 class="text-uppercase text-muted fw-bold mb-2 fs-6">
                            <i class="fas fa-calendar-alt me-2"></i>Created Date
                        </h6>
                        <p class="text-secondary fs-5 mb-0">
                            <span class="badge bg-light text-dark border">
                                <i class="far fa-clock me-1"></i>
                                @Model.CreatedAt.ToString("MMM dd, yyyy - hh:mm tt")
                            </span>
                        </p>
                    </div>

                    <!-- Action Buttons (Mobile visible) -->
                    <div class="d-md-none mt-4 pt-3 border-top">
                        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning w-100 mb-2">
                            <i class="fas fa-edit"></i> Edit Product
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </a>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>